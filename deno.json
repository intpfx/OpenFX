{
  "nodeModulesDir": "auto",
  "workspace": [
    "./entry/web",
    "./domains/e"
  ],
  "tasks": {
    "fmt": "deno fmt .",
    "lint": "deno lint .",
    "guard:deno-only": "deno run -A ./tools/guard-deno-only.ts",
    "test": "deno test --allow-env domains/e/tests domains/downip/tests domains/proxy/tests entry/web/tests domains/_shared/tests",
    "check": "deno fmt --check . && deno lint . && deno task guard:deno-only && deno test --allow-env domains/e/tests domains/downip/tests domains/proxy/tests entry/web/tests domains/_shared/tests",
    "web:dev": "deno task --config entry/web/deno.json dev",
    "web:build": "deno task --config entry/web/deno.json build",
    "web:preview": "deno task --config entry/web/deno.json preview"
  },
  "fmt": {
    "lineWidth": 88,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ],
      "exclude": [
        "no-unversioned-import"
      ]
    },
    "exclude": [
      "domains/wanone/",
      "domains/chinagas-wms-qrcode/",
      "entry/web/public/bewlyscript/",
      "entry/web/src/",
      "domains/_shared/opfs-finder.ts",
      "domains/_shared/island-notice.ts",
      "domains/_shared/idb-engine.ts",
      "domains/_shared/ffmpeg-pipeline.ts",
      "domains/_shared/opfs-engine.ts",
      "domains/costing-assistant/",
      "domains/finlyzer/",
      "domains/hlc/",
      "domains/freemac/",
      "domains/BewlyScript/",
      "domains/LivpExplorer/"
    ]
  },
  "exclude": [
    "dist",
    "domains/gasmap",
    "domains/costing-assistant/",
    "domains/finlyzer/",
    "entry/web/public/bewlyscript/",
    "domains/hlc/",
    "domains/freemac/",
    "domains/BewlyScript/",
    "domains/LivpExplorer/",
    ".sisyphus"
  ],
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/expect": "jsr:@std/expect@^1.0.17",
    "@chenglou/pretext": "npm:@chenglou/pretext@^0.0.8",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^5.1.4",
    "animejs": "npm:animejs@^4.4.1",
    "gsap": "npm:gsap@^3.15.0",
    "h3": "npm:h3@^1.15.11",
    "nitropack": "npm:nitropack@^2.13.4",
    "nitropack/": "npm:nitropack@^2.13.4/",
    "react": "npm:react@^19.1.0",
    "react-dom": "npm:react-dom@^19.1.0",
    "react-dom/": "npm:react-dom@^19.1.0/",
    "vite-plus": "npm:vite-plus@^0.1.21"
  },
  "deploy": {
    "org": "universes"
  }
}
