{
  "nodeModulesDir": "auto",
  "workspace": [
    "./apps/web",
    "./packages/core"
  ],
  "tasks": {
    "fmt": "deno fmt .",
    "lint": "deno lint .",
    "test": "deno test --allow-env packages/core/tests apps/web/tests",
    "check": "deno fmt --check . && deno lint . && deno test --allow-env packages/core/tests apps/web/tests",
    "web:dev": "deno task --config apps/web/deno.json dev",
    "web:build": "deno task --config apps/web/deno.json build",
    "web:preview": "deno task --config apps/web/deno.json preview"

  },
  "fmt": {
    "lineWidth": 88,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ],
      "exclude": [
        "no-unversioned-import"
      ]
    }
  },
  "exclude": [
    "dist",
    "apps/web/_fresh",
    ".sisyphus"
  ],
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19"
  },
  "deploy": {
    "org": "universes"
  }
}
