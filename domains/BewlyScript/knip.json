{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/contentScripts/index.ts",
    "src/inject/index.ts",
    "src/tests/**/*.ts",
    "src/userscript/**/*.ts",
    "src/components/**",
    "scripts/build-userscript.ts",
    "*.config.*"
  ],
  "ignore": ["src/components/Settings/**"],
  "ignoreDependencies": [
    "@iconify/json",
    "uno.css"
  ],
  "ignoreBinaries": ["gh"],
  "rules": {
    "types": "off",
    "enumMembers": "off",
    "exports": "off"
  }
}
