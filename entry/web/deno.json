{
  "tasks": {
    "dev": "cd ../.. && deno run --config deno.json --lock deno.lock --frozen -A npm:concurrently@9.2.1 -k -n web,server -c blue,green \"deno run --config deno.json --lock deno.lock --frozen -A npm:vite-plus@0.1.21/vp dev --config entry/web/vite.config.ts\" \"cd entry/web && deno run --config deno.json --lock ../../deno.lock --frozen -A npm:nitropack@2.13.4 dev\"",
    "build": "deno run --config deno.json --lock ../../deno.lock --frozen -A tools/build-with-metadata.ts",
    "preview": "deno task build && deno run -A .output/server/index.ts",
    "test": "deno test --allow-env tests"
  },
  "imports": {
    "@std/expect": "jsr:@std/expect@^1.0.17",
    "@/": "./",
    "@chenglou/pretext": "npm:@chenglou/pretext@^0.0.8",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^5.1.4",
    "animejs": "npm:animejs@^4.4.1",
    "gsap": "npm:gsap@^3.15.0",
    "h3": "npm:h3@^1.15.11",
    "nitropack": "npm:nitropack@^2.13.4",
    "nitropack/": "npm:nitropack@^2.13.4/",
    "react": "npm:react@^19.1.0",
    "react-dom": "npm:react-dom@^19.1.0",
    "react-dom/": "npm:react-dom@^19.1.0/",
    "vite-plus": "npm:vite-plus@^0.1.21"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext",
      "deno.ns",
      "deno.unstable"
    ]
  }
}
